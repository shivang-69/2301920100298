{
  "info": {
    "_postman_id": "8e36fa7c-dbd4-4a25-83e9-a417e298516d",
    "name": "Campus Notification System API",
    "description": "API collection for testing and verifying the Campus Notification System backend services.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Get Notifications (Paginated & Filtered)",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "http://localhost:5000/api/notifications?page=1&limit=5&type=All",
          "protocol": "http",
          "host": [
            "localhost"
          ],
          "port": "5000",
          "path": [
            "api",
            "notifications"
          ],
          "query": [
            {
              "key": "page",
              "value": "1",
              "description": "Page number to retrieve"
            },
            {
              "key": "limit",
              "value": "5",
              "description": "Number of items per page"
            },
            {
              "key": "type",
              "value": "All",
              "description": "Filter by type (All, Placement, Result, Event)"
            }
          ]
        },
        "description": "Retrieve a list of notifications sorted by newest date first, with optional type filtering and pagination."
      },
      "response": []
    },
    {
      "name": "Get Unread Notifications Count",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "http://localhost:5000/api/notifications/unread-count",
          "protocol": "http",
          "host": [
            "localhost"
          ],
          "port": "5000",
          "path": [
            "api",
            "notifications",
            "unread-count"
          ]
        },
        "description": "Fetch the total count of notifications that have not been read by the user yet."
      },
      "response": []
    },
    {
      "name": "Create Mock Notification",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"type\": \"Placement\",\n  \"title\": \"Google Software Engineer Interview Updates\",\n  \"message\": \"Shortlisted candidates for Google SWE Intern role have received details for Round 1 technical interviews on their student email.\"\n}"
        },
        "url": {
          "raw": "http://localhost:5000/api/notifications",
          "protocol": "http",
          "host": [
            "localhost"
          ],
          "port": "5000",
          "path": [
            "api",
            "notifications"
          ]
        },
        "description": "Create a new notification entry (simulates external academic, placement, or event coordinators sending notices)."
      },
      "response": []
    },
    {
      "name": "Mark Notification as Read",
      "request": {
        "method": "PATCH",
        "header": [],
        "url": {
          "raw": "http://localhost:5000/api/notifications/1/read",
          "protocol": "http",
          "host": [
            "localhost"
          ],
          "port": "5000",
          "path": [
            "api",
            "notifications",
            "1",
            "read"
          ]
        },
        "description": "Mark a specific notification (by ID) as read. (Note: Replace '1' with a valid notification ID from the GET list)."
      },
      "response": []
    }
  ]
}
